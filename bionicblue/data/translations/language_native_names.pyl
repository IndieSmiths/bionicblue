# dictionary with native names for languages;
#
# we also include some element to identify the place when the
# language is used in more than one region, like "English (USA)" and
# "English (United Kingdom)";
#
# although this is a Python dict, there's no need to worry about the
# insertion of malicious code, since it only represents data and is
# loaded with the safe literal_eval() function, from the ast module
# from Python's standard library;
{
    'en_us': "English (USA)",
    'pt_br': "Português do Brasil"
}
